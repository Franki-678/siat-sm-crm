# ─── Copiar a .env.local para desarrollo ─────────────────────────────────────
# En Vercel: Settings → Environment Variables → pegar estos valores

# ── n8n (Oracle Cloud) ────────────────────────────────────────────────────────
# URL del webhook SIAT-SM en tu instancia de n8n
# Importar n8n/siat-sm-workflow.json → activar → copiar Production URL aquí
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://n8n.maniaco.online/webhook/siat-sm

# ── Supabase ──────────────────────────────────────────────────────────────────
# Proyecto: xysledaqzlelvppdkbvp
# URL siempre es: https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xysledaqzlelvppdkbvp.supabase.co

# Anon key (PÚBLICA — safe para client): Supabase → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SIAT-SM CRM
NEXT_PUBLIC_APP_VERSION=1.1.0
