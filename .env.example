# ─── Copiar a .env.local para desarrollo ─────────────────────────────────────
# En Vercel: Settings → Environment Variables → pegar estos valores

# n8n hosteado en Oracle Cloud
# El webhook recibe el JSON y llama a motor_decision.py
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://TU_SUBDOMINIO.n8n.cloud/webhook/siat-sm

# Supabase — proyecto xysledaqzlelvppdkbvp
# URL siempre es: https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xysledaqzlelvppdkbvp.supabase.co

# Anon key: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App
NEXT_PUBLIC_APP_NAME=SIAT-SM CRM
NEXT_PUBLIC_APP_VERSION=1.0.0
